<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Task</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>

    <header>
        <h1><a href="AdminDashboard.html">School Task Portal</a></h1>
        <nav>
            <ul>
                <li><a href="Profile.html">Profile</a></li>
                <li><a href="AdminDashboard.html">Dashboard</a></li>
                <li><a href="Homepage.html">Log out</a></li>
            </ul>
        </nav>
    </header>

    <hr>

    <main>
        <section class="form-container">
            <h2>Edit Task Details</h2>
            <p>Update the information below to modify the assigned task.</p>

            <form action="AdminDashboard.html" method="GET">
                <fieldset>
                    <legend>Modify Task</legend>

                    <div>
                        <label for="taskId">Task ID:</label><br>
                        <input type="number" id="taskId" name="taskId" value="101" readonly>
                    </div>
                    <br>

                    <div>
                        <label for="taskTitle">Task Title:</label><br>
                        <input type="text" id="taskTitle" name="taskTitle" value="Grade Midterm Exams" required>
                    </div>
                    <br>

                    <div>
                        <label for="teacherName">Assigned Teacher:</label><br>
                        <select id="teacherName" name="teacherName" required>
                            <option value="mr_smith" selected>Mr. Smith</option>
                            <option value="mrs_davis">Mrs. Davis</option>
                            <option value="ms_johnson">Ms. Johnson</option>
                        </select>
                    </div>
                    <br>

                    <div>
                        <label for="priority">Priority Level:</label><br>
                        <select id="priority" name="priority" required>
                            <option value="low">Low</option>
                            <option value="medium">Medium</option>
                            <option value="high" selected>High</option>
                        </select>
                    </div>
                    <br>

                    <div>
                        <label for="description">Task Description:</label><br>
                        <textarea id="description" name="description" rows="5" cols="40" required>Please finish grading the grade 10 science midterms by Friday.</textarea>
                    </div>
                    <br>

                    <div>
                        <label for="createdBy">Created By (Admin):</label><br>
                        <input type="text" id="createdBy" name="createdBy" value="CurrentAdminUser" readonly>
                    </div>
                    <br>
                </fieldset>
                <br>
                
                <div class="form-actions">
                    <button type="submit">Save Changes</button>
                    <a href="AdminDashboard.html"><button type="button">Cancel</button></a>
                </div>
            </form>
        </section>
    </main>

    <hr>

    <footer>
        <p class="copyrights"><small>&copy; 2026 School Task Portal. All rights reserved.</small></p>
    </footer>

</body>

</html>
